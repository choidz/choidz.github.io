---
import "../styles/global.css";
import Analytics from "../components/Analytics.astro";

const {
  title = "최오키 개발블로그",
  description = "개발과 운영 경험을 기록하는 최성현의 기술 블로그입니다.",
  image = "/images/profile.jpeg",
  canonical = Astro.url.pathname,
  type = "website",
  showSearch = false,
  hideHeader = false,
} = Astro.props;

const siteUrl = "https://choidz.github.io";
const canonicalUrl = new URL(canonical, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href={new URL("/rss.xml", siteUrl).toString()} />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content="#0f172a" />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content="ko_KR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <Analytics />
    <slot name="head" />
  </head>
  <body>
    {!hideHeader && (
      <header class="site-header">
        <div class="site-header-inner">
          <a class="site-title" href="/">
            <span>최오키 개발블로그</span>
          </a>
          {showSearch && (
            <div class="header-search">
              <label>
                <span class="sr-only">검색</span>
                <svg aria-hidden="true" viewBox="0 0 16 16">
                  <path d="M11.25 11.25L14 14" />
                  <circle cx="7.5" cy="7.5" r="4.75" />
                </svg>
                <input id="post-search" type="search" placeholder="키워드로 글을 검색해 보세요" />
              </label>
            </div>
          )}
          <nav class="site-nav" aria-label="주요 메뉴">
            <a class="active" href="/">블로그</a>
          </nav>
        </div>
      </header>
    )}
    <slot />
  </body>
</html>
