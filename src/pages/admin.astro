---
import BaseLayout from "../layouts/BaseLayout.astro";

const gaPropertyId = import.meta.env.PUBLIC_GA_PROPERTY_ID || "514244650";
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || "";
const adminApiUrl = import.meta.env.PUBLIC_ADMIN_API_URL || "";
const adminUsername = import.meta.env.PUBLIC_ADMIN_USERNAME || "";
const adminPasswordHash = import.meta.env.PUBLIC_ADMIN_PASSWORD_HASH || "";
const adminMode = adminApiUrl ? "serverless" : googleClientId ? "oauth" : "links";
const analyticsHomeUrl = `https://analytics.google.com/analytics/web/#/p${gaPropertyId}/reports/intelligenthome`;
const realtimeUrl = `https://analytics.google.com/analytics/web/#/p${gaPropertyId}/realtime/pages?params=_u..nav%3Dmaui`;
---

<BaseLayout
  title="Admin | 최오키 개발블로그"
  description="최오키 개발블로그 방문 통계 관리자 페이지입니다."
  canonical="/admin"
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <main
    class="admin-shell admin-shell--compact"
    data-admin-mode={adminMode}
    data-admin-username={adminUsername}
    data-admin-password-hash={adminPasswordHash}
    data-ga-property-id={gaPropertyId}
    data-google-client-id={googleClientId}
    data-admin-api-url={adminApiUrl}
    data-analytics-url={analyticsHomeUrl}
  >
    <section class="admin-login" data-admin-login-panel>
      <form data-admin-login-form>
        <p>Admin</p>
        <h1>관리자 로그인</h1>
        <label>
          <span>아이디</span>
          <input name="username" autocomplete="username" required />
        </label>
        <label>
          <span>비밀번호</span>
          <input name="password" type="password" autocomplete="current-password" required />
        </label>
        <button type="submit">들어가기</button>
        <small data-admin-login-message>아이디와 비밀번호를 입력하세요.</small>
      </form>
    </section>

    <div class="admin-content" data-admin-content hidden>
      <section class="admin-summary">
        <div>
          <p>Admin</p>
          <h1>블로그 통계</h1>
          <span>상단은 최근 28일, 페이지 표는 누적 기준입니다.</span>
        </div>
        <button type="button" data-admin-action>
          {adminMode === "links"
            ? "Google Analytics 열기"
            : adminMode === "oauth"
              ? "Google 권한 연결"
              : "통계 새로고침"}
        </button>
      </section>

      <p class="admin-message" data-admin-message>
        {adminMode === "links"
          ? "아직 GA 자동조회 연결값이 없습니다. Google OAuth Client ID 또는 서버리스 API URL을 연결하면 로그인 직후 자동으로 조회됩니다."
          : adminMode === "oauth"
            ? "Google 권한 연결을 누르면 GA 권한 승인 후 이 화면에서 통계를 불러옵니다."
            : "로그인 후 자동으로 통계를 불러옵니다."}
      </p>

      <section class="admin-metrics" aria-label="핵심 통계">
        <article>
          <span>현재 접속자</span>
          <strong data-active-users>{adminMode === "links" ? "연결 필요" : "-"}</strong>
        </article>
        <article>
          <span>실시간 조회수</span>
          <strong data-realtime-views>{adminMode === "links" ? "연결 필요" : "-"}</strong>
        </article>
        <article>
          <span>28일 조회수</span>
          <strong data-total-views>{adminMode === "links" ? "연결 필요" : "-"}</strong>
        </article>
        <article>
          <span>28일 사용자</span>
          <strong data-total-users>{adminMode === "links" ? "연결 필요" : "-"}</strong>
        </article>
      </section>

      <section class="admin-data-grid">
        <article class="admin-panel">
          <div class="admin-panel-heading">
            <h2>페이지별 총 조회수</h2>
            <a href={analyticsHomeUrl} target="_blank" rel="noreferrer">GA에서 자세히 보기</a>
          </div>
          <div class="admin-table-wrap">
            <table>
              <thead>
                <tr>
                  <th>페이지</th>
                  <th>총 조회수</th>
                  <th>총 사용자</th>
                </tr>
              </thead>
              <tbody data-page-rows>
                <tr>
                  <td colspan="3">
                    {adminMode === "links"
                      ? "자동조회 연결값이 필요합니다."
                      : adminMode === "oauth"
                        ? "Google 권한 연결을 누르면 표시됩니다."
                        : "통계를 불러오는 중입니다."}
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </article>

        <article class="admin-panel">
          <div class="admin-panel-heading">
            <h2>실시간 페이지</h2>
            <a href={realtimeUrl} target="_blank" rel="noreferrer">실시간 화면 열기</a>
          </div>
          <div class="admin-table-wrap">
            <table>
              <thead>
                <tr>
                  <th>페이지</th>
                  <th>접속자</th>
                  <th>조회수</th>
                </tr>
              </thead>
              <tbody data-realtime-rows>
                <tr>
                  <td colspan="3">
                    {adminMode === "links"
                      ? "자동조회 연결값이 필요합니다."
                      : adminMode === "oauth"
                        ? "Google 권한 연결을 누르면 표시됩니다."
                        : "통계를 불러오는 중입니다."}
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </article>
      </section>
    </div>
  </main>

  <script>
    const root = document.querySelector(".admin-shell");
    const loginPanel = document.querySelector("[data-admin-login-panel]");
    const loginForm = document.querySelector("[data-admin-login-form]");
    const loginMessage = document.querySelector("[data-admin-login-message]");
    const content = document.querySelector("[data-admin-content]");
    const actionButton = document.querySelector("[data-admin-action]");
    const message = document.querySelector("[data-admin-message]");
    const realtimeRows = document.querySelector("[data-realtime-rows]");
    const pageRows = document.querySelector("[data-page-rows]");
    const activeUsers = document.querySelector("[data-active-users]");
    const realtimeViews = document.querySelector("[data-realtime-views]");
    const totalViews = document.querySelector("[data-total-views]");
    const totalUsers = document.querySelector("[data-total-users]");

    const mode = root?.dataset.adminMode || "links";
    const expectedUsername = root?.dataset.adminUsername || "";
    const expectedPasswordHash = root?.dataset.adminPasswordHash || "";
    const propertyId = root?.dataset.gaPropertyId || "";
    const clientId = root?.dataset.googleClientId || "";
    const adminApiUrl = root?.dataset.adminApiUrl || "";
    const analyticsUrl = root?.dataset.analyticsUrl || "";
    const authKey = "choioki-admin-auth";
    const gaTokenKey = "choioki-ga-access-token";

    function setLoginMessage(text, type = "info") {
      if (!loginMessage) return;
      loginMessage.textContent = text;
      loginMessage.dataset.type = type;
    }

    function setMessage(text, type = "info") {
      if (!message) return;
      message.textContent = text;
      message.dataset.type = type;
    }

    async function sha256(text) {
      const bytes = new TextEncoder().encode(text);
      const digest = await crypto.subtle.digest("SHA-256", bytes);
      return [...new Uint8Array(digest)].map((byte) => byte.toString(16).padStart(2, "0")).join("");
    }

    function isAuthConfigured() {
      return Boolean(expectedUsername && expectedPasswordHash);
    }

    async function showAdmin({ autoLoad = true } = {}) {
      loginPanel?.setAttribute("hidden", "");
      content?.removeAttribute("hidden");
      if (autoLoad && mode !== "links") {
        await autoLoadReports();
      }
    }

    async function handleLogin(event) {
      event.preventDefault();

      if (!isAuthConfigured()) {
        setLoginMessage("관리자 아이디/비밀번호가 아직 설정되지 않았습니다.", "error");
        return;
      }

      const formData = new FormData(event.currentTarget);
      const username = String(formData.get("username") || "").trim();
      const password = String(formData.get("password") || "");
      const passwordHash = await sha256(password);

      if (username !== expectedUsername || passwordHash !== expectedPasswordHash) {
        setLoginMessage("아이디 또는 비밀번호가 맞지 않습니다.", "error");
        return;
      }

      sessionStorage.setItem(authKey, expectedPasswordHash);
      await showAdmin();
    }

    function renderRows(target, rows, columns) {
      if (!target) return;
      target.replaceChildren();

      if (!rows.length) {
        const row = document.createElement("tr");
        const cell = document.createElement("td");
        cell.colSpan = columns;
        cell.textContent = "표시할 데이터가 없습니다.";
        row.append(cell);
        target.append(row);
        return;
      }

      for (const values of rows) {
        const row = document.createElement("tr");
        for (const value of values) {
          const cell = document.createElement("td");
          cell.textContent = value;
          row.append(cell);
        }
        target.append(row);
      }
    }

    function setNeedsSetup() {
      if (activeUsers) activeUsers.textContent = "연결 필요";
      if (realtimeViews) realtimeViews.textContent = "연결 필요";
      if (totalViews) totalViews.textContent = "연결 필요";
      if (totalUsers) totalUsers.textContent = "연결 필요";
      renderRows(pageRows, [["Google OAuth Client ID 또는 서버리스 API URL을 연결해야 자동조회됩니다.", "-", "-"]], 3);
      renderRows(realtimeRows, [["Google Analytics에서 직접 확인할 수 있습니다.", "-", "-"]], 3);
      setMessage("현재는 GA 자동조회 연결값이 없어 이 화면에서 숫자를 직접 불러올 수 없습니다.", "warning");
    }

    function applySummaryPayload(payload) {
      if (activeUsers) activeUsers.textContent = String(payload.realtime?.activeUsers ?? "-");
      if (realtimeViews) realtimeViews.textContent = String(payload.realtime?.views ?? "-");
      if (totalViews) totalViews.textContent = String(payload.pages?.views ?? "-");
      if (totalUsers) totalUsers.textContent = String(payload.pages?.users ?? "-");

      renderRows(pageRows, payload.pages?.rows || [], 3);
      renderRows(realtimeRows, payload.realtime?.rows || [], 3);
      setMessage("업데이트 완료", "success");
    }

    function getCachedGaToken() {
      try {
        const cached = JSON.parse(localStorage.getItem(gaTokenKey) || "null");
        if (!cached?.accessToken || !cached?.expiresAt) return "";
        if (Number(cached.expiresAt) <= Date.now() + 60000) {
          localStorage.removeItem(gaTokenKey);
          return "";
        }
        return cached.accessToken;
      } catch {
        localStorage.removeItem(gaTokenKey);
        return "";
      }
    }

    function cacheGaToken(accessToken, expiresIn) {
      const safeExpiresIn = Number(expiresIn || 3600);
      localStorage.setItem(gaTokenKey, JSON.stringify({
        accessToken,
        expiresAt: Date.now() + Math.max(60, safeExpiresIn - 60) * 1000,
      }));
    }

    function clearCachedGaToken() {
      localStorage.removeItem(gaTokenKey);
    }

    async function loadServerlessReports() {
      setMessage("통계를 불러오는 중입니다...");
      const baseUrl = adminApiUrl.replace(/\/$/, "");
      const response = await fetch(`${baseUrl}/analytics/summary`, {
        credentials: "include",
        headers: { Accept: "application/json" },
      });
      if (!response.ok) {
        const text = await response.text();
        throw new Error(text || `Admin API request failed: ${response.status}`);
      }
      applySummaryPayload(await response.json());
    }

    function loadGoogleIdentityScript() {
      return new Promise((resolve, reject) => {
        if (window.google?.accounts?.oauth2) {
          resolve();
          return;
        }
        const script = document.createElement("script");
        script.src = "https://accounts.google.com/gsi/client";
        script.async = true;
        script.defer = true;
        script.onload = resolve;
        script.onerror = reject;
        document.head.append(script);
      });
    }

    async function gaFetch(path, body, accessToken) {
      const response = await fetch(`https://analyticsdata.googleapis.com/v1beta/${path}`, {
        method: "POST",
        headers: {
          Authorization: `Bearer ${accessToken}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
      });
      if (!response.ok) {
        const text = await response.text();
        throw new Error(text || `GA API request failed: ${response.status}`);
      }
      return response.json();
    }

    function metric(row, index) {
      return row.metricValues?.[index]?.value || "0";
    }

    function dimension(row, index) {
      return row.dimensionValues?.[index]?.value || "";
    }

    async function loadOAuthReports(accessToken) {
      setMessage("통계를 불러오는 중입니다...");

      const [realtime, totals, pages] = await Promise.all([
        gaFetch(
          `properties/${propertyId}:runRealtimeReport`,
          {
            dimensions: [{ name: "unifiedScreenName" }],
            metrics: [{ name: "activeUsers" }, { name: "screenPageViews" }],
            limit: 10,
            orderBys: [{ metric: { metricName: "activeUsers" }, desc: true }],
          },
          accessToken
        ),
        gaFetch(
          `properties/${propertyId}:runReport`,
          {
            dateRanges: [{ startDate: "28daysAgo", endDate: "today" }],
            metrics: [{ name: "screenPageViews" }, { name: "totalUsers" }],
          },
          accessToken
        ),
        gaFetch(
          `properties/${propertyId}:runReport`,
          {
            dateRanges: [{ startDate: "2020-01-01", endDate: "today" }],
            dimensions: [{ name: "pagePath" }],
            metrics: [{ name: "screenPageViews" }, { name: "totalUsers" }],
            dimensionFilter: {
              filter: {
                fieldName: "pagePath",
                stringFilter: { matchType: "BEGINS_WITH", value: "/blog/" },
              },
            },
            limit: 50,
            orderBys: [{ metric: { metricName: "screenPageViews" }, desc: true }],
          },
          accessToken
        ),
      ]);

      const realtimeData = realtime.rows || [];
      const totalData = totals.rows || [];
      const pageData = pages.rows || [];

      applySummaryPayload({
        realtime: {
          activeUsers: realtimeData.reduce((sum, row) => sum + Number(metric(row, 0)), 0),
          views: realtimeData.reduce((sum, row) => sum + Number(metric(row, 1)), 0),
          rows: realtimeData.map((row) => [dimension(row, 0) || "/", metric(row, 0), metric(row, 1)]),
        },
        pages: {
          views: totalData.reduce((sum, row) => sum + Number(metric(row, 0)), 0),
          users: totalData.reduce((sum, row) => sum + Number(metric(row, 1)), 0),
          rows: pageData.map((row) => [dimension(row, 0), metric(row, 0), metric(row, 1)]),
        },
      });
    }

    async function requestAnalyticsAccess() {
      if (mode === "links") {
        window.open(analyticsUrl, "_blank", "noopener,noreferrer");
        setNeedsSetup();
        return;
      }

      if (mode === "serverless") {
        await loadServerlessReports();
        return;
      }

      await loadGoogleIdentityScript();
      window.google.accounts.oauth2.initTokenClient({
        client_id: clientId,
        scope: "https://www.googleapis.com/auth/analytics.readonly",
        callback: async (response) => {
          if (response.error) {
            setMessage(`Google 로그인 실패: ${response.error}`, "error");
            return;
          }
          try {
            cacheGaToken(response.access_token, response.expires_in);
            await loadOAuthReports(response.access_token);
          } catch (error) {
            clearCachedGaToken();
            setMessage(error.message || "GA 데이터를 불러오지 못했습니다.", "error");
          }
        },
      }).requestAccessToken();
    }

    async function autoLoadReports() {
      if (mode === "links") {
        setNeedsSetup();
        return;
      }

      if (mode === "oauth") {
        const cachedToken = getCachedGaToken();
        if (cachedToken) {
          try {
            await loadOAuthReports(cachedToken);
            return;
          } catch {
            clearCachedGaToken();
          }
        }
        setMessage("Google 권한 연결을 누르면 GA 데이터를 불러옵니다.");
        return;
      }

      await requestAnalyticsAccess();
    }

    if (sessionStorage.getItem(authKey) === expectedPasswordHash && isAuthConfigured()) {
      showAdmin({ autoLoad: false });
      autoLoadReports().catch((error) => {
        setMessage(error.message || "통계를 불러오지 못했습니다.", "error");
      });
    }

    loginForm?.addEventListener("submit", (event) => {
      handleLogin(event).catch((error) => {
        setLoginMessage(error.message || "로그인 처리 중 오류가 발생했습니다.", "error");
      });
    });

    actionButton?.addEventListener("click", async () => {
      try {
        await requestAnalyticsAccess();
      } catch (error) {
        setMessage(error.message || "통계를 불러오지 못했습니다.", "error");
      }
    });
  </script>
</BaseLayout>
