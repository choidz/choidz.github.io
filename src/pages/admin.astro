---
import BaseLayout from "../layouts/BaseLayout.astro";

const gaPropertyId = import.meta.env.PUBLIC_GA_PROPERTY_ID || "514244650";
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || "";
const adminApiUrl = import.meta.env.PUBLIC_ADMIN_API_URL || "";
const analyticsHomeUrl = `https://analytics.google.com/analytics/web/#/p${gaPropertyId}/reports/intelligenthome`;
const realtimeUrl = `https://analytics.google.com/analytics/web/#/p${gaPropertyId}/realtime/pages?params=_u..nav%3Dmaui`;
const pagesUrl = `https://analytics.google.com/analytics/web/#/p${gaPropertyId}/reports/explorer?params=_u..nav%3Dmaui`;
---

<BaseLayout
  title="Admin | 최오키 개발블로그"
  description="최오키 개발블로그 방문 통계 관리자 페이지입니다."
  canonical="/admin"
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <main
    class="admin-shell"
    data-ga-property-id={gaPropertyId}
    data-google-client-id={googleClientId}
    data-admin-api-url={adminApiUrl}
  >
    <section class="admin-hero">
      <div>
        <p>Private analytics</p>
        <h1>블로그 통계 관리자</h1>
        <span>Google Analytics 권한이 있는 계정으로 로그인하면 이 페이지 안에서 실시간 접속자와 게시글별 조회수를 확인할 수 있습니다.</span>
      </div>
      <div class="admin-hero-actions">
        <a href={realtimeUrl} target="_blank" rel="noreferrer">GA 실시간 열기</a>
        <a href={pagesUrl} target="_blank" rel="noreferrer">게시글별 조회 열기</a>
      </div>
    </section>

    <section class="admin-status-grid" aria-label="Admin status">
      <article>
        <span>GA Property</span>
        <strong>{gaPropertyId}</strong>
        <p>이 속성의 데이터를 조회합니다.</p>
      </article>
      <article>
        <span>OAuth</span>
        <strong>{googleClientId ? "Ready" : "Setup needed"}</strong>
        <p>{googleClientId ? "Google 로그인으로 직접 조회할 수 있습니다." : "PUBLIC_GOOGLE_CLIENT_ID 등록 후 직접 조회가 켜집니다."}</p>
      </article>
      <article>
        <span>Serverless API</span>
        <strong>{adminApiUrl ? "Connected" : "Optional"}</strong>
        <p>{adminApiUrl ? "외부 서버리스 API URL이 설정되어 있습니다." : "Cloudflare/Vercel 백엔드를 붙일 수 있습니다."}</p>
      </article>
    </section>

    <section class="admin-panel">
      <div class="admin-panel-heading">
        <div>
          <h2>내 도메인에서 바로 보기</h2>
          <p>Google OAuth Client ID가 설정되어 있으면 버튼 하나로 GA Data API를 읽습니다.</p>
        </div>
        <button type="button" data-admin-login>Google로 통계 조회</button>
      </div>
      <p class="admin-message" data-admin-message>
        아직 Google OAuth Client ID가 설정되지 않았습니다. 아래 직접 링크로 GA 화면을 볼 수 있고, OAuth 설정을 추가하면 이 페이지 안에서 표가 표시됩니다.
      </p>

      <div class="admin-metrics">
        <article>
          <span>Realtime active users</span>
          <strong data-active-users>-</strong>
        </article>
        <article>
          <span>Last 28 days views</span>
          <strong data-total-views>-</strong>
        </article>
        <article>
          <span>Last 28 days users</span>
          <strong data-total-users>-</strong>
        </article>
      </div>

      <div class="admin-tables">
        <section>
          <h3>실시간 접속 페이지</h3>
          <div class="admin-table-wrap">
            <table>
              <thead>
                <tr>
                  <th>페이지</th>
                  <th>접속자</th>
                </tr>
              </thead>
              <tbody data-realtime-rows>
                <tr><td colspan="2">로그인 후 표시됩니다.</td></tr>
              </tbody>
            </table>
          </div>
        </section>

        <section>
          <h3>게시글별 조회수</h3>
          <div class="admin-table-wrap">
            <table>
              <thead>
                <tr>
                  <th>페이지</th>
                  <th>조회수</th>
                  <th>사용자</th>
                </tr>
              </thead>
              <tbody data-page-rows>
                <tr><td colspan="3">로그인 후 표시됩니다.</td></tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </section>

    <section class="admin-panel admin-panel--links">
      <h2>바로가기</h2>
      <div>
        <a href={analyticsHomeUrl} target="_blank" rel="noreferrer">Google Analytics 홈</a>
        <a href={realtimeUrl} target="_blank" rel="noreferrer">실시간 접속자</a>
        <a href={pagesUrl} target="_blank" rel="noreferrer">페이지 및 화면</a>
        <a href="https://search.google.com/search-console?resource_id=https%3A%2F%2Fchoidz.github.io%2F&hl=ko" target="_blank" rel="noreferrer">Search Console</a>
      </div>
    </section>
  </main>

  <script>
    const root = document.querySelector(".admin-shell");
    const loginButton = document.querySelector("[data-admin-login]");
    const message = document.querySelector("[data-admin-message]");
    const realtimeRows = document.querySelector("[data-realtime-rows]");
    const pageRows = document.querySelector("[data-page-rows]");
    const activeUsers = document.querySelector("[data-active-users]");
    const totalViews = document.querySelector("[data-total-views]");
    const totalUsers = document.querySelector("[data-total-users]");

    const propertyId = root?.dataset.gaPropertyId || "";
    const clientId = root?.dataset.googleClientId || "";
    const adminApiUrl = root?.dataset.adminApiUrl || "";

    function setMessage(text, type = "info") {
      if (!message) return;
      message.textContent = text;
      message.dataset.type = type;
    }

    function renderRows(target, rows, columns) {
      if (!target) return;
      target.replaceChildren();
      if (!rows.length) {
        const row = document.createElement("tr");
        const cell = document.createElement("td");
        cell.colSpan = columns;
        cell.textContent = "표시할 데이터가 없습니다.";
        row.append(cell);
        target.append(row);
        return;
      }

      for (const values of rows) {
        const row = document.createElement("tr");
        for (const value of values) {
          const cell = document.createElement("td");
          cell.textContent = value;
          row.append(cell);
        }
        target.append(row);
      }
    }

    function loadGoogleIdentityScript() {
      return new Promise((resolve, reject) => {
        if (window.google?.accounts?.oauth2) {
          resolve();
          return;
        }
        const script = document.createElement("script");
        script.src = "https://accounts.google.com/gsi/client";
        script.async = true;
        script.defer = true;
        script.onload = resolve;
        script.onerror = reject;
        document.head.append(script);
      });
    }

    async function gaFetch(path, body, accessToken) {
      const response = await fetch(`https://analyticsdata.googleapis.com/v1beta/${path}`, {
        method: "POST",
        headers: {
          Authorization: `Bearer ${accessToken}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
      });
      if (!response.ok) {
        const text = await response.text();
        throw new Error(text || `GA API request failed: ${response.status}`);
      }
      return response.json();
    }

    function metric(row, index) {
      return row.metricValues?.[index]?.value || "0";
    }

    function dimension(row, index) {
      return row.dimensionValues?.[index]?.value || "";
    }

    function applySummaryPayload(payload) {
      if (activeUsers) activeUsers.textContent = String(payload.realtime?.activeUsers ?? "-");
      if (totalViews) totalViews.textContent = String(payload.pages?.views ?? "-");
      if (totalUsers) totalUsers.textContent = String(payload.pages?.users ?? "-");

      renderRows(realtimeRows, payload.realtime?.rows || [], 2);
      renderRows(pageRows, payload.pages?.rows || [], 3);
      setMessage("조회가 완료됐습니다.", "success");
    }

    async function loadServerlessReports() {
      setMessage("서버리스 API에서 Google Analytics 데이터를 불러오는 중입니다...");
      const baseUrl = adminApiUrl.replace(/\/$/, "");
      const response = await fetch(`${baseUrl}/analytics/summary`, {
        credentials: "include",
        headers: { Accept: "application/json" },
      });
      if (!response.ok) {
        const text = await response.text();
        throw new Error(text || `Admin API request failed: ${response.status}`);
      }
      applySummaryPayload(await response.json());
    }

    async function loadReports(accessToken) {
      setMessage("Google Analytics 데이터를 불러오는 중입니다...");

      const realtime = await gaFetch(
        `properties/${propertyId}:runRealtimeReport`,
        {
          dimensions: [{ name: "pagePath" }],
          metrics: [{ name: "activeUsers" }],
          limit: 10,
          orderBys: [{ metric: { metricName: "activeUsers" }, desc: true }],
        },
        accessToken
      );

      const pages = await gaFetch(
        `properties/${propertyId}:runReport`,
        {
          dateRanges: [{ startDate: "28daysAgo", endDate: "today" }],
          dimensions: [{ name: "pagePath" }, { name: "pageTitle" }],
          metrics: [{ name: "screenPageViews" }, { name: "totalUsers" }],
          dimensionFilter: {
            filter: {
              fieldName: "pagePath",
              stringFilter: { matchType: "BEGINS_WITH", value: "/blog/" },
            },
          },
          limit: 30,
          orderBys: [{ metric: { metricName: "screenPageViews" }, desc: true }],
        },
        accessToken
      );

      const realtimeData = realtime.rows || [];
      const pageData = pages.rows || [];

      const currentUsers = realtimeData.reduce((sum, row) => sum + Number(metric(row, 0)), 0);
      const views = pageData.reduce((sum, row) => sum + Number(metric(row, 0)), 0);
      const users = pageData.reduce((sum, row) => sum + Number(metric(row, 1)), 0);

      if (activeUsers) activeUsers.textContent = String(currentUsers);
      if (totalViews) totalViews.textContent = String(views);
      if (totalUsers) totalUsers.textContent = String(users);

      renderRows(
        realtimeRows,
        realtimeData.map((row) => [dimension(row, 0) || "/", metric(row, 0)]),
        2
      );
      renderRows(
        pageRows,
        pageData.map((row) => [dimension(row, 0), metric(row, 0), metric(row, 1)]),
        3
      );
      setMessage("조회가 완료됐습니다.", "success");
    }

    async function requestAnalyticsAccess() {
      if (adminApiUrl) {
        try {
          await loadServerlessReports();
        } catch (error) {
          setMessage(error.message || "서버리스 API에서 데이터를 불러오지 못했습니다.", "error");
        }
        return;
      }

      if (!clientId) {
        setMessage("PUBLIC_GOOGLE_CLIENT_ID가 아직 설정되지 않았습니다. Google Cloud OAuth Client ID를 만든 뒤 GitHub Variables에 추가해야 합니다.", "warning");
        return;
      }

      await loadGoogleIdentityScript();
      const tokenClient = window.google.accounts.oauth2.initTokenClient({
        client_id: clientId,
        scope: "https://www.googleapis.com/auth/analytics.readonly",
        callback: async (response) => {
          if (response.error) {
            setMessage(`Google 로그인 실패: ${response.error}`, "error");
            return;
          }
          try {
            await loadReports(response.access_token);
          } catch (error) {
            setMessage(error.message || "GA 데이터를 불러오지 못했습니다.", "error");
          }
        },
      });
      tokenClient.requestAccessToken();
    }

    loginButton?.addEventListener("click", requestAnalyticsAccess);

    if (clientId) {
      setMessage("Google로 통계 조회를 누르면 이 페이지에서 GA 데이터를 불러옵니다.");
    }
  </script>
</BaseLayout>
