---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getAllTags, getPostUrl, sortPosts } from "../lib/posts.js";

const postModules = import.meta.glob("../content/blog/*.md", { eager: true });
const posts = sortPosts(Object.values(postModules));
const tags = getAllTags(posts);
const latestPosts = posts.slice(0, 4);
---

<BaseLayout
  title="CHOI.DEV | 기술 블로그"
  description="개발, DevOps, 데이터, 운영 경험을 실무 관점으로 정리하는 최성현의 기술 블로그입니다."
  showSearch={true}
>
  <main class="page-shell">
    <div class="layout-grid">
      <section class="post-column" aria-labelledby="post-list-title">
        <div class="post-list-heading">
          <h1 id="post-list-title">모든 글</h1>
          <p id="search-result" class="search-result" hidden></p>
        </div>

        <div class="post-list">
          {posts.map((post) => (
            <article
              class="post-card"
              data-title={post.frontmatter.title.toLowerCase()}
              data-description={post.frontmatter.description.toLowerCase()}
              data-tags={(post.frontmatter.tags ?? []).join(" ").toLowerCase()}
            >
              <a href={getPostUrl(post.frontmatter.slug)}>
                <div class="post-meta">
                  <time datetime={post.frontmatter.date}>{formatDate(post.frontmatter.date)}</time>
                  <span aria-hidden="true">•</span>
                  <span>{post.frontmatter.readingMinutes}분 분량</span>
                </div>
                <div>
                  <h2>{post.frontmatter.title}</h2>
                  <p>{post.frontmatter.description}</p>
                </div>
                <div class="post-tags">
                  {(post.frontmatter.tags ?? []).map((tag) => <span>{tag}</span>)}
                </div>
                <div class="post-card-footer">
                  <span>{post.frontmatter.readingMinutes}분 분량</span>
                  <strong>계속 읽기 →</strong>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>

      <aside class="sidebar">
        <section class="sidebar-card">
          <div class="sidebar-card-header">
            <h2>최신 등록 글</h2>
          </div>
          <ol class="latest-list">
            {latestPosts.map((post, index) => (
              <li>
                <span class="latest-index">{index + 1}</span>
                <div>
                  <a href={getPostUrl(post.frontmatter.slug)}>{post.frontmatter.title}</a>
                  <p>{formatDate(post.frontmatter.date)}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>

        <section class="sidebar-card">
          <div class="sidebar-card-header">
            <h2>태그</h2>
          </div>
          <div class="tag-cloud">
            <button type="button" data-tag-filter="">전체</button>
            {tags.map((tag) => (
              <button type="button" data-tag-filter={tag.toLowerCase()}>{tag}</button>
            ))}
          </div>
        </section>

        <section class="community-card">
          <h2>개발자로서의 여정을 기록하고 있어요</h2>
          <p>최신 글은 블로그에서 확인해 주세요. 꾸준히 업데이트하며 성장 과정을 공유합니다.</p>
          <a href="/">블로그 최신 글 보기</a>
        </section>
      </aside>
    </div>
  </main>

  <script>
    const searchInput = document.querySelector("#post-search");
    const result = document.querySelector("#search-result");
    const cards = Array.from(document.querySelectorAll(".post-card"));
    const tagButtons = Array.from(document.querySelectorAll("[data-tag-filter]"));
    let activeTag = "";

    function applyFilters() {
      const query = (searchInput?.value || "").trim().toLowerCase();
      let visible = 0;

      for (const card of cards) {
        const haystack = [
          card.dataset.title,
          card.dataset.description,
          card.dataset.tags,
        ].join(" ");
        const matchesQuery = !query || haystack.includes(query);
        const matchesTag = !activeTag || (card.dataset.tags || "").includes(activeTag);
        const shouldShow = matchesQuery && matchesTag;
        card.hidden = !shouldShow;
        if (shouldShow) visible += 1;
      }

      if (result) {
        const hasFilter = query || activeTag;
        result.hidden = !hasFilter;
        result.textContent = hasFilter
          ? `${query ? `"${query}" ` : ""}${activeTag ? `${activeTag} ` : ""}검색 결과 (${visible}건)`
          : "";
      }
    }

    searchInput?.addEventListener("input", applyFilters);
    for (const button of tagButtons) {
      button.addEventListener("click", () => {
        activeTag = button.dataset.tagFilter || "";
        for (const item of tagButtons) item.classList.toggle("active", item === button);
        applyFilters();
      });
    }
  </script>
</BaseLayout>
