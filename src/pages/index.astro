---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDate, getAllTags, getPostUrl, sortPosts } from "../lib/posts.js";

const postModules = import.meta.glob("../content/blog/*.md", { eager: true });
const posts = sortPosts(Object.values(postModules));
const tags = getAllTags(posts);
const categories = [
  { label: "Engineering", filter: "" },
  { label: "DevOps", filter: "devops" },
  { label: "Linux", filter: "linux" },
  { label: "Monitoring", filter: "monitoring" },
];

function getPostRaw(post) {
  if (typeof post.rawContent === "function") return post.rawContent();
  return post.rawContent ?? post.body ?? "";
}

function getPostImage(post) {
  const raw = getPostRaw(post);
  const localImage = raw.match(/!\[[^\]]*\]\((\/images\/posts\/[^)\s]+)\)/);
  return post.frontmatter.image ?? localImage?.[1] ?? "";
}

function getCategory(post) {
  return post.frontmatter.tags?.[0] ?? "Engineering";
}
---

<BaseLayout
  title="CHOI.DEV | Tech Notes"
  description="개발, DevOps, 운영 경험을 실무 관점으로 정리하는 기술 블로그입니다."
  showSearch={false}
>
  <main class="toss-home toss-home--articles-only">
    <section class="toss-topbar" aria-label="글 분류">
      <nav class="toss-tabs">
        {categories.map((category, index) => (
          <button class={index === 0 ? "active" : ""} type="button" data-tag-filter={category.filter}>
            {category.label}
          </button>
        ))}
      </nav>
    </section>

    <section id="all-articles" class="toss-main-grid toss-main-grid--single">
      <div class="toss-article-column">
        <div class="toss-section-heading">
          <div>
            <h1>전체 아티클</h1>
            <p>운영, 자동화, Linux, 모니터링 실무 기록을 모았습니다.</p>
          </div>
          <p id="search-result" hidden></p>
        </div>

        <label class="toss-search">
          <span class="sr-only">글 검색</span>
          <svg aria-hidden="true" viewBox="0 0 16 16">
            <path d="M11.25 11.25L14 14" />
            <circle cx="7.5" cy="7.5" r="4.75" />
          </svg>
          <input id="post-search" type="search" placeholder="키워드로 글 검색" />
        </label>

        <div class="toss-article-list">
          {posts.map((post) => (
            <article
              class="post-card toss-article-card"
              data-title={post.frontmatter.title.toLowerCase()}
              data-description={post.frontmatter.description.toLowerCase()}
              data-tags={(post.frontmatter.tags ?? []).join(" ").toLowerCase()}
            >
              <a href={getPostUrl(post.frontmatter.slug)}>
                <div class="toss-card-copy">
                  <div class="post-meta">
                    <span>{getCategory(post)}</span>
                    <time datetime={post.frontmatter.date}>{formatDate(post.frontmatter.date)}</time>
                    <span>{post.frontmatter.readingMinutes}분 읽기</span>
                  </div>
                  <h2>{post.frontmatter.title}</h2>
                  <p>{post.frontmatter.description}</p>
                </div>

                <div class="toss-card-media">
                  {getPostImage(post) ? (
                    <img src={getPostImage(post)} alt="" loading="lazy" />
                  ) : (
                    <div class="toss-image-fallback">{getCategory(post)}</div>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <script>
    const searchInput = document.querySelector("#post-search");
    const result = document.querySelector("#search-result");
    const cards = Array.from(document.querySelectorAll(".post-card"));
    const tagButtons = Array.from(document.querySelectorAll("[data-tag-filter]"));
    let activeTag = "";

    function applyFilters() {
      const query = (searchInput?.value || "").trim().toLowerCase();
      let visible = 0;

      for (const card of cards) {
        const haystack = [
          card.dataset.title,
          card.dataset.description,
          card.dataset.tags,
        ].join(" ");
        const matchesQuery = !query || haystack.includes(query);
        const matchesTag = !activeTag || (card.dataset.tags || "").includes(activeTag);
        const shouldShow = matchesQuery && matchesTag;
        card.hidden = !shouldShow;
        if (shouldShow) visible += 1;
      }

      if (result) {
        const hasFilter = query || activeTag;
        result.hidden = !hasFilter;
        result.textContent = hasFilter
          ? `${query ? `"${query}" ` : ""}${activeTag ? `${activeTag} ` : ""}검색 결과 ${visible}건`
          : "";
      }
    }

    searchInput?.addEventListener("input", applyFilters);
    for (const button of tagButtons) {
      button.addEventListener("click", () => {
        activeTag = button.dataset.tagFilter || "";
        for (const item of tagButtons) {
          item.classList.toggle("active", item.dataset.tagFilter === activeTag);
        }
        applyFilters();
      });
    }
  </script>
</BaseLayout>
