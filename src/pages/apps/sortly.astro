---
import BaseLayout from "../../layouts/BaseLayout.astro";

const storeUrl = "https://apps.microsoft.com/detail/9nvc2q1z7361?hl=ko-KR&gl=KR&cid=github_pages_sortly";
const guideUrl = "/blog/sortly-%EB%8B%A4%EC%9A%B4%EB%A1%9C%EB%93%9C-%ED%8F%B4%EB%8D%94-%EC%9E%90%EB%8F%99-%EC%A0%95%EB%A6%AC-%ED%94%84%EB%A1%9C%EA%B7%B8%EB%9E%A8-%EC%99%84%EB%B2%BD-%EA%B0%80%EC%9D%B4%EB%93%9C";
const screenshots = "/images/apps/sortly";

const faqs = [
  {
    question: "파일이 바로 이동되는 게 불안하지 않나요?",
    answer: "정리 전에 이동될 폴더와 파일을 미리 확인할 수 있습니다. 정리 후에도 작업 단위로 원래 위치에 되돌릴 수 있습니다.",
  },
  {
    question: "파일 내용이 외부로 전송되나요?",
    answer: "일반 정리, 규칙, 중복 검사, 폴더 인사이트는 PC에서 처리됩니다. AI 정리는 사용자가 직접 선택하고 동의한 경우에만 파일명과 지원 문서 일부를 분석하며, 이미지와 음악 내용은 외부로 보내지 않습니다.",
  },
  {
    question: "무료로 사용할 수 있나요?",
    answer: "네. 수동 파일 정리, 정리 미리보기, 되돌리기, 중복 검사와 한 폴더 자동 정리를 무료로 사용할 수 있습니다. 여러 폴더 자동화와 예약 정리 같은 고급 기능은 Pro에서 제공됩니다.",
  },
  {
    question: "어떤 Windows에서 실행되나요?",
    answer: "Windows 10 이상에서 Microsoft Store를 통해 설치하고 업데이트할 수 있습니다. 한국어와 영어를 지원합니다.",
  },
];

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Sortly",
  applicationCategory: "UtilitiesApplication",
  operatingSystem: "Windows 10, Windows 11",
  description: "다운로드 폴더와 작업 폴더를 미리보기, 규칙, 중복 검사, 되돌리기로 안전하게 정리하는 Windows 파일 자동화 앱입니다.",
  url: "https://choidz.github.io/apps/sortly",
  downloadUrl: storeUrl,
  inLanguage: ["ko", "en"],
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "KRW",
  },
  featureList: [
    "정리 전 미리보기",
    "파일 유형과 이름 규칙 기반 자동 분류",
    "중복 파일 검사",
    "작업 단위 되돌리기",
    "폴더 자동 감시",
    "AI 정리",
  ],
};
---

<BaseLayout
  title="Sortly | Windows 파일 자동 정리"
  description="다운로드 폴더를 미리 확인하고 안전하게 자동 정리하세요. 규칙, 중복 검사, 한 번에 되돌리기와 Pro 자동화를 지원합니다."
  image="/images/apps/sortly/og-sortly.png"
  canonical="/apps/sortly"
  hideHeader={true}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(softwareSchema)}></script>

  <div class="sortly-page">
    <header class="product-header">
      <div class="product-nav">
        <a class="product-brand" href="/apps/sortly" aria-label="Sortly 홈">
          <img src="/images/apps/sortly/icon-128.png" width="38" height="38" alt="" />
          <span>Sortly</span>
        </a>
        <nav aria-label="Sortly 페이지 메뉴">
          <a href="#features">기능</a>
          <a href="#safety">안전</a>
          <a href="#plans">플랜</a>
          <a class="nav-cta" href={storeUrl} target="_blank" rel="noreferrer" data-store-cta="nav">무료 설치</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero section-shell">
        <div class="hero-copy">
          <p class="eyebrow"><span></span> Windows 10·11 · Microsoft Store</p>
          <h1>다운로드 폴더,<br /><strong>정리할 시간을 없애세요.</strong></h1>
          <p class="hero-lead">Sortly가 새 파일을 지켜보고, 원하는 규칙으로 분류합니다. 이동하기 전에 확인하고, 마음에 들지 않으면 한 번에 되돌릴 수 있습니다.</p>
          <div class="hero-actions">
            <a class="button button-primary" href={storeUrl} target="_blank" rel="noreferrer" data-store-cta="hero">
              Microsoft Store에서 무료 설치
              <span aria-hidden="true">↗</span>
            </a>
            <a class="button button-secondary" href="#how-it-works">작동 방식 보기</a>
          </div>
          <ul class="hero-notes" aria-label="제품 정보">
            <li>회원가입 없음</li>
            <li>한국어·영어</li>
            <li>자동 업데이트</li>
          </ul>
        </div>

        <div class="hero-visual">
          <div class="window-glow"></div>
          <figure class="app-window app-window-main">
            <img src={`${screenshots}/01-main-free.png`} width="1120" height="820" alt="Sortly에서 다운로드 폴더 파일을 확인하는 메인 화면" />
          </figure>
          <div class="floating-card floating-card-top">
            <span class="status-dot"></span>
            <div><strong>자동 정리 준비</strong><small>새 파일을 기다리는 중</small></div>
          </div>
          <div class="floating-card floating-card-bottom">
            <strong>미리 보고 정리</strong><span aria-hidden="true">→</span>
          </div>
        </div>
      </section>

      <section class="trust-strip" aria-label="Sortly 핵심 원칙">
        <div class="section-shell trust-grid">
          <div><strong>먼저 확인</strong><span>실행 전 이동 결과 미리보기</span></div>
          <div><strong>다시 되돌리기</strong><span>정리 작업을 원래 위치로 복원</span></div>
          <div><strong>내 규칙대로</strong><span>확장자와 이름 키워드 설정</span></div>
          <div><strong>필요할 때만 AI</strong><span>명시적 선택과 동의 후 사용</span></div>
        </div>
      </section>

      <section id="how-it-works" class="workflow section-shell">
        <div class="section-heading centered">
          <p class="eyebrow">3단계면 충분합니다</p>
          <h2>정리는 빠르게.<br />결정권은 그대로.</h2>
          <p>폴더를 고르고, 결과를 확인하고, 실행하세요. Sortly는 사용자가 확인하지 않은 결정을 몰래 진행하지 않습니다.</p>
        </div>
        <ol class="workflow-grid">
          <li><span>01</span><strong>폴더 선택</strong><p>Downloads부터 작업 폴더까지 정리할 위치를 선택합니다.</p></li>
          <li><span>02</span><strong>이동 결과 확인</strong><p>어떤 파일이 어디로 이동하는지 그룹별로 미리 봅니다.</p></li>
          <li><span>03</span><strong>정리 또는 되돌리기</strong><p>한 번에 정리하고 필요하면 작업 전체를 다시 복원합니다.</p></li>
        </ol>
      </section>

      <section id="features" class="feature-stack">
        <article class="feature-row section-shell">
          <div class="feature-copy">
            <p class="eyebrow">Preview first</p>
            <h2>움직이기 전에<br />결과부터 보여드립니다.</h2>
            <p>카테고리별 대상 파일과 이동 위치를 먼저 확인합니다. 중요한 파일이 섞였다면 실행하지 않고 규칙부터 바꿀 수 있습니다.</p>
            <ul class="check-list">
              <li>파일 유형별 자동 분류</li>
              <li>이름 키워드·사용자 규칙</li>
              <li>최소 크기·기간 필터와 제외 폴더</li>
            </ul>
          </div>
          <figure class="feature-shot">
            <img src={`${screenshots}/05-organize-preview.png`} width="1120" height="820" loading="lazy" alt="정리될 파일과 대상 폴더를 보여주는 Sortly 정리 미리보기" />
          </figure>
        </article>

        <article class="feature-row feature-row-reverse section-shell">
          <div class="feature-copy">
            <p class="eyebrow">Smart automation</p>
            <h2>반복되는 정리는<br />규칙으로 남기세요.</h2>
            <p>폴더를 읽기 전용으로 분석해 반복되는 파일 패턴과 예상 절약 시간을 제안합니다. 적용 여부는 사용자가 선택합니다.</p>
            <ul class="check-list">
              <li>자동화 가능한 파일과 추천 그룹</li>
              <li>문서·스크린샷 등 맞춤 규칙 제안</li>
              <li>여러 폴더 자동화와 예약 정리 <em>Pro</em></li>
            </ul>
          </div>
          <figure class="feature-shot">
            <img src={`${screenshots}/07-automation-preview.png`} width="1120" height="820" loading="lazy" alt="자동화 가능한 파일과 추천 규칙을 분석한 Sortly 자동 정리 미리보기" />
          </figure>
        </article>

        <article class="feature-row section-shell">
          <div class="feature-copy">
            <p class="eyebrow">Clean with confidence</p>
            <h2>중복은 찾고,<br />실수는 되돌립니다.</h2>
            <p>파일 크기를 먼저 비교한 뒤 내용 해시를 확인해 중복 그룹을 찾습니다. 삭제할 파일은 휴지통으로 보내며, 이동 기록은 작업 단위로 복원할 수 있습니다.</p>
            <ul class="check-list">
              <li>하위 폴더 포함 중복 검사</li>
              <li>큰 중복 그룹 우선 표시</li>
              <li>정리 작업 한 번에 되돌리기</li>
            </ul>
          </div>
          <div class="dual-shots">
            <figure class="feature-shot"><img src={`${screenshots}/06-duplicates.png`} width="1120" height="820" loading="lazy" alt="내용이 같은 중복 파일을 그룹으로 표시한 화면" /></figure>
            <figure class="feature-shot feature-shot-offset"><img src={`${screenshots}/11-undo.png`} width="1120" height="820" loading="lazy" alt="파일 정리 작업을 원래 위치로 되돌리는 화면" /></figure>
          </div>
        </article>

        <article class="feature-row feature-row-reverse section-shell">
          <div class="feature-copy">
            <p class="eyebrow">Pro control center</p>
            <h2>여러 폴더도<br />한곳에서 관리하세요.</h2>
            <p>Pro에서는 폴더별 자동화, 인사이트, AI 정리와 예약 작업을 한 패널에서 시작하고 관리할 수 있습니다.</p>
            <ul class="check-list">
              <li>여러 감시 폴더와 개별 일시정지</li>
              <li>매일·매주·매월 예약 정리</li>
              <li>폴더 인사이트와 로컬 안전 분석</li>
            </ul>
          </div>
          <figure class="feature-shot">
            <img src={`${screenshots}/13-pro-panel.png`} width="1120" height="820" loading="lazy" alt="자동화 관리, 폴더 인사이트, AI 정리와 예약 정리가 모인 Sortly Pro 패널" />
          </figure>
        </article>
      </section>

      <section id="safety" class="safety-section">
        <div class="section-shell safety-grid">
          <div class="safety-copy">
            <p class="eyebrow light">Local-first</p>
            <h2>파일 정리는<br />먼저 PC 안에서.</h2>
            <p>일반 정리, 규칙, 중복 검사와 폴더 인사이트는 기기에서 처리됩니다. 클라우드 AI는 사용자가 기능을 직접 선택하고 동의한 경우에만 사용됩니다.</p>
            <a href="/privacy-policy/sortly.html">개인정보 처리방침 보기 <span aria-hidden="true">→</span></a>
          </div>
          <div class="safety-points">
            <article><span>01</span><strong>회원가입 없음</strong><p>계정을 만들거나 로그인하지 않고 바로 시작합니다.</p></article>
            <article><span>02</span><strong>로컬 기록</strong><p>정리 규칙과 이동 기록은 기본적으로 사용자의 기기에 저장됩니다.</p></article>
            <article><span>03</span><strong>AI 선택 사용</strong><p>이미지와 음악 내용은 AI 문서 분석을 위해 외부로 보내지 않습니다.</p></article>
            <article><span>04</span><strong>통계 해제 가능</strong><p>익명 사용 통계는 앱 설정에서 언제든 끌 수 있습니다.</p></article>
          </div>
        </div>
      </section>

      <section id="plans" class="plans section-shell">
        <div class="section-heading centered">
          <p class="eyebrow">Start free</p>
          <h2>무료로 시작하고,<br />자동화가 더 필요할 때 Pro로.</h2>
        </div>
        <div class="plan-grid">
          <article class="plan-card">
            <div><p>Free</p><h3>안전한 파일 정리의 기본</h3><span>무료</span></div>
            <ul>
              <li>수동 파일 정리와 미리보기</li>
              <li>중복 파일 검사</li>
              <li>작업 단위 되돌리기</li>
              <li>한 폴더 자동 정리</li>
              <li>AI 정리 20개 체험</li>
            </ul>
            <a class="button button-secondary full" href={storeUrl} target="_blank" rel="noreferrer" data-store-cta="free-plan">무료로 설치</a>
          </article>
          <article class="plan-card plan-card-pro">
            <div><p>Pro</p><h3>반복 정리를 맡기는 자동화</h3><span>Microsoft Store 구독</span></div>
            <ul>
              <li>여러 폴더 동시 자동화</li>
              <li>폴더별 일시정지와 관리</li>
              <li>예약 정리와 오래된 파일 압축</li>
              <li>폴더 인사이트와 안전 분석</li>
              <li>월 AI 정리 1,000개</li>
            </ul>
            <a class="button button-primary full" href={storeUrl} target="_blank" rel="noreferrer" data-store-cta="pro-plan">앱에서 Pro 확인</a>
          </article>
        </div>
      </section>

      <section class="faq section-shell">
        <div class="section-heading faq-heading">
          <p class="eyebrow">FAQ</p>
          <h2>설치 전에<br />궁금한 점</h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq, index) => (
            <details open={index === 0}>
              <summary>{faq.question}<span aria-hidden="true">+</span></summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="final-cta section-shell">
        <div>
          <p class="eyebrow light">Your folders, on autopilot</p>
          <h2>오늘 받은 파일부터<br />깔끔하게 시작하세요.</h2>
          <p>Microsoft Store에서 무료로 설치하고, 정리될 파일을 먼저 확인해 보세요.</p>
        </div>
        <a class="button button-white" href={storeUrl} target="_blank" rel="noreferrer" data-store-cta="final">
          Sortly 무료 설치 <span aria-hidden="true">↗</span>
        </a>
      </section>
    </main>

    <footer class="product-footer">
      <div class="section-shell footer-inner">
        <div class="footer-brand"><img src="/images/apps/sortly/icon-128.png" width="32" height="32" alt="" /><strong>Sortly</strong><span>Windows 파일 자동 정리</span></div>
        <nav aria-label="Sortly 관련 링크">
          <a href={guideUrl}>사용 가이드</a>
          <a href="/privacy-policy/sortly.html">개인정보 처리방침</a>
          <a href="/privacy-policy/sortly-terms.html">이용약관</a>
          <a href="/">개발 블로그</a>
        </nav>
        <p>© 2026 choioki. Microsoft Store에서 제공됩니다.</p>
      </div>
    </footer>
  </div>

  <script>
    document.querySelectorAll("[data-store-cta]").forEach((link) => {
      link.addEventListener("click", () => {
        const source = link.getAttribute("data-store-cta") || "unknown";
        if (typeof window.gtag === "function") {
          window.gtag("event", "sortly_store_click", { source });
        }
      });
    });
  </script>
</BaseLayout>

<style>
  :global(html) { scroll-behavior: smooth; background: #f6f9ff; }
  :global(body) { background: #f6f9ff; }
  :global(.sortly-page) { --blue: #1578f2; --blue-dark: #075bc4; --ink: #111827; --muted: #58657a; --line: #dfe7f2; color: var(--ink); background: #fff; overflow: hidden; }
  .section-shell { width: min(1180px, calc(100% - 48px)); margin-inline: auto; }
  .product-header { position: relative; z-index: 50; border-bottom: 1px solid rgba(216, 226, 239, .75); background: rgba(255,255,255,.88); backdrop-filter: blur(18px); }
  .product-nav { display: flex; width: min(1180px, calc(100% - 48px)); min-height: 76px; align-items: center; justify-content: space-between; gap: 24px; margin-inline: auto; }
  .product-brand { display: inline-flex; align-items: center; gap: 11px; font-size: 21px; font-weight: 850; letter-spacing: -.03em; }
  .product-brand img { border-radius: 9px; box-shadow: 0 8px 20px rgba(21, 120, 242, .2); }
  .product-nav nav { display: flex; align-items: center; gap: 8px; color: #435066; font-size: 14px; font-weight: 720; }
  .product-nav nav a { padding: 10px 13px; border-radius: 999px; }
  .product-nav nav a:hover { color: var(--blue); background: #f0f6ff; }
  .product-nav nav .nav-cta { margin-left: 8px; padding-inline: 18px; color: #fff; background: var(--blue); }
  .product-nav nav .nav-cta:hover { color: #fff; background: var(--blue-dark); }
  .hero { display: grid; grid-template-columns: minmax(0, .88fr) minmax(560px, 1.12fr); gap: clamp(46px, 6vw, 88px); align-items: center; min-height: 760px; padding-block: 86px 104px; }
  .eyebrow { margin: 0 0 18px; color: var(--blue); font-size: 13px; font-weight: 850; letter-spacing: .08em; text-transform: uppercase; }
  .eyebrow > span { display: inline-block; width: 8px; height: 8px; margin-right: 8px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 0 5px rgba(34,197,94,.12); vertical-align: 1px; }
  .hero h1 { margin: 0; color: var(--ink); font-size: clamp(48px, 5.5vw, 72px); font-weight: 880; letter-spacing: -.055em; line-height: 1.08; word-break: keep-all; }
  .hero h1 strong { color: var(--blue); font-weight: inherit; }
  .hero-lead { max-width: 610px; margin: 28px 0 0; color: var(--muted); font-size: 19px; line-height: 1.8; word-break: keep-all; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 34px; }
